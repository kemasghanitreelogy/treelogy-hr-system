# Copy to .env.local and fill in. Values below are EXAMPLES (placeholders), not real keys.

# Supabase — leave blank to run on built-in seed data; fill in to use the live backend.
# Example:
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Server-only (admin tasks / seeding). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# Web Push (VAPID). Generate real keys with:  npx web-push generate-vapid-keys --json
# Example:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# mailto: email OR https: URL you control (not verified by push services).
VAPID_SUBJECT=mailto:you@example.com
